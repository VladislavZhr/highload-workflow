DATABASE_DSN=postgres://postgres:postgres@postgres:5432/highload_workflow?sslmode=disable

KAFKA_BROKERS=kafka-1:29092,kafka-2:29092,kafka-3:29092
KAFKA_GROUP_ID=highload-workflow-handler-group
KAFKA_TOPIC=input-topic

KAFKA_MIN_BYTES=1
KAFKA_MAX_BYTES=104857600
KAFKA_MAX_WAIT=2s

WORKERS_COUNT=4
JOBS_BUFFER_SIZE=64
RESULTS_BUFFER_SIZE=64

READ_BATCH_TIMEOUT=5s
COMMIT_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s

MAX_RETRY_COUNT=3
LEASE_DURATION=30s

DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=10m
DB_PING_TIMEOUT=5s